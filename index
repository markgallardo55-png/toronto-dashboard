<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="color-scheme" content="light only"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="default"/>
<meta name="apple-mobile-web-app-title" content="Toronto"/>
<title>Toronto Weather</title>
<style>
:root{color-scheme:light only;--bg-000:rgb(255,255,255);--bg-100:rgb(250,249,245);--bg-200:rgb(245,244,237);--bg-300:rgb(240,238,230);--bg-400:rgb(232,230,220);--text-100:rgb(20,20,19);--text-200:rgb(61,61,58);--text-400:rgb(115,114,108);--border:rgba(31,30,29,0.12);--border-med:rgba(31,30,29,0.18);--border-strong:rgba(31,30,29,0.28);--danger:rgb(181,51,51);--danger-bg:rgba(181,51,51,0.08);--danger-border:rgba(181,51,51,0.25);--accent-coral:rgb(207,92,54);--font:"Anthropic Sans",system-ui,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;--radius-sm:8px;--radius-md:12px;--radius-lg:16px}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;background:#faf9f5 !important;color:#141413 !important}
body{font-family:var(--font);background:#faf9f5 !important;color:#141413 !important;min-height:100vh;padding:40px 20px 80px;-webkit-text-size-adjust:100%}
.wrap{max-width:900px;margin:0 auto}
.header{display:flex;justify-content:space-between;align-items:flex-end;padding-bottom:20px;border-bottom:1px solid var(--border-strong);margin-bottom:24px;gap:12px}
.city{font-size:clamp(48px,9vw,88px);font-weight:700;letter-spacing:-2px;line-height:.9;color:var(--text-100)}
.region{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--text-400);margin-top:6px}
.cur-block{text-align:right}
.cur-temp{font-size:clamp(40px,7vw,72px);font-weight:300;line-height:1;color:var(--text-100);letter-spacing:-1px}
.cur-cond{font-size:14px;color:var(--text-200);margin-top:4px}
.cur-wind{font-size:11px;color:var(--text-400);margin-top:2px;letter-spacing:.5px}
.section-label{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--text-400);margin-bottom:12px;font-weight:500}
.divider{height:1px;background:var(--border);margin:28px 0}
.scroll-wrap{overflow-x:auto;overflow-y:visible;margin-bottom:24px;padding-top:4px;padding-bottom:8px;-webkit-overflow-scrolling:touch}
.scroll-wrap::-webkit-scrollbar{height:3px}
.scroll-wrap::-webkit-scrollbar-thumb{background:var(--border-med);border-radius:2px}
.cards-row{display:flex;gap:8px;min-width:max-content}
.day-card{width:118px;min-width:118px;background:var(--bg-000);border:1px solid var(--border);border-radius:var(--radius-lg);padding:14px 12px;text-align:center;cursor:pointer;transition:all .15s ease;display:flex;flex-direction:column;-webkit-tap-highlight-color:transparent;user-select:none;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.day-card:hover{background:var(--bg-200);border-color:var(--border-med)}
.day-card.selected{background:var(--bg-300);border-color:var(--border-strong)}
.card-label{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;color:var(--text-400)}
.day-card.selected .card-label{color:var(--text-200)}
.card-date{font-size:10px;color:var(--text-400);margin-top:2px}
.card-icon{font-size:24px;margin:10px 0 8px;display:block}
.card-high{font-size:22px;font-weight:600;display:block;line-height:1}
.card-low{font-size:12px;color:var(--text-400);margin-top:3px;display:block}
.temp-bar-wrap{margin-top:8px;height:3px;border-radius:2px;background:var(--bg-400);position:relative;overflow:hidden}
.temp-bar{position:absolute;top:0;bottom:0;border-radius:2px;background:var(--accent-coral)}
.walk-dot-wrap{margin-top:8px;display:flex;justify-content:center;gap:4px}
.walk-dot{width:6px;height:6px;border-radius:50%}
.dot-label{font-size:8px;color:var(--text-400);margin-top:3px;letter-spacing:.5px}
.pills-area{margin-top:8px;display:flex;flex-direction:column;gap:3px;flex:1}
.pill-slot{border-radius:6px;display:flex;flex-direction:column;justify-content:center;padding:6px 8px;overflow:hidden}
.pill-time{font-size:10px;font-weight:600;color:var(--text-200);white-space:nowrap;line-height:1.2;text-align:left}
.pill-title{font-size:10px;color:var(--text-200);line-height:1.35;text-align:left;word-break:break-word}
.detail{background:var(--bg-000);border:1px solid var(--border);border-radius:var(--radius-lg);margin-bottom:24px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.05)}

/* TOD cards — 3-column grid on desktop, stacked on mobile */
.tod-row{display:grid;grid-template-columns:repeat(3,1fr);gap:0}
.tod-card{padding:16px 14px;border-right:1px solid var(--border);position:relative;background:var(--bg-000)}
.tod-card:last-child{border-right:none}
.tod-top-bar{height:3px;position:absolute;top:0;left:0;right:0}
.tod-period{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;color:var(--text-400);margin-top:4px}
.tod-time{display:block;font-size:9px;color:var(--text-400);margin-top:2px;opacity:.7}

/* Walk score block inside tod card */
.tod-score-block{border-radius:10px;padding:8px 10px;margin-top:10px}
.tod-score-label{font-size:8px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:3px}
.tod-score-num{font-size:22px;font-weight:700;line-height:1}
.tod-score-slash{font-size:11px;font-weight:400;opacity:.5}
.tod-score-denom{font-size:11px;font-weight:400;opacity:.5}
.tod-score-word{font-size:11px;font-weight:700;margin-top:2px}
.tod-score-bar{height:3px;border-radius:2px;margin-top:6px;overflow:hidden}
.tod-score-bar-fill{height:100%;border-radius:2px}

/* Metric mini-cards */
.tod-metric-cards{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-top:6px}
.tod-metric-card{background:var(--bg-200);border-radius:6px;padding:5px 7px}
.tod-metric-card-label{font-size:8px;color:var(--text-400);font-weight:500;margin-bottom:2px}
.tod-metric-card-value{font-size:11px;font-weight:700;color:var(--text-100)}
.tod-metric-card-sub{font-size:9px;color:var(--text-400);margin-top:1px}

/* Top section of tod card */
.tod-icon{font-size:22px;margin:8px 0 4px;display:block}
.tod-cond-label{font-size:12px;font-weight:600;color:var(--text-100);margin-top:4px}
.tod-walk-insight{font-size:10px;color:var(--text-400);margin-top:2px;line-height:1.4}
.tod-temp-hero{font-size:24px;font-weight:700;line-height:1;color:var(--text-100);text-align:right}
.tod-feels{font-size:10px;color:var(--text-400);margin-top:2px;text-align:right}
.tod-paw{font-size:10px;letter-spacing:2px;opacity:.6;margin-top:2px;display:block}

/* Getting Ready section */
.tod-clothing-divider{border:none;border-top:1px solid var(--border);margin:10px 0 8px}
.tod-ready-heading{font-size:8px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text-400);margin-bottom:8px}
.tod-ready-sub{font-size:7px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-400);margin:8px 0 5px;padding-top:7px;border-top:1px solid var(--border)}
.tod-ready-sub:first-of-type{margin-top:0;border-top:none}
.tod-layer-row{display:flex;align-items:flex-start;gap:5px;padding:4px 0;border-bottom:1px solid var(--border)}
.tod-layer-row:last-of-type{border-bottom:none;padding-bottom:0}
.tod-layer-icon{font-size:11px;flex-shrink:0;margin-top:1px}
.tod-layer-inner{flex:1}
.tod-layer-headline{font-size:10px;font-weight:600;color:var(--text-100);line-height:1.3}
.tod-layer-note{font-size:9px;color:var(--text-400);margin-top:1px;line-height:1.3}
.tod-rain-alert{display:flex;align-items:flex-start;gap:5px;background:rgba(74,127,165,0.08);border:1px solid rgba(74,127,165,0.18);border-radius:5px;padding:5px 7px;margin-top:6px;margin-bottom:3px}
.tod-rain-alert-icon{font-size:11px;flex-shrink:0;margin-top:1px}
.tod-rain-alert-body{flex:1}
.tod-rain-alert-title{font-size:10px;font-weight:600;color:rgb(50,100,140);margin-bottom:1px}
.tod-rain-alert-sub{font-size:9px;color:rgb(70,120,160);line-height:1.3}
.tod-milo-section{margin-top:0}
.tod-milo-tip{display:flex;align-items:flex-start;gap:5px;margin-bottom:4px}
.tod-milo-tip:last-child{margin-bottom:0}
.tod-milo-tip-icon{font-size:11px;flex-shrink:0;margin-top:1px}
.tod-milo-tip-text{flex:1}
.tod-milo-tip-label{font-size:10px;font-weight:600;color:var(--text-200);margin-bottom:1px}
.tod-milo-tip-note{font-size:9px;color:var(--text-400);line-height:1.3}

/* Detail grid — events/reminders */
.detail-grid{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--border)}
.detail-col{padding:18px 16px;border-right:1px solid var(--border)}
.detail-col:last-child{border-right:none}
.detail-col-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:600;color:var(--text-400);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.no-events{font-size:11px;color:var(--text-400);font-style:italic}
.event-pill{padding:10px 12px;border-radius:var(--radius-sm);background:var(--bg-200);border-left:3px solid transparent;margin-bottom:8px;display:flex;align-items:flex-start;gap:8px}
.event-title{font-size:11px;font-weight:600;color:var(--text-100);margin-bottom:2px;line-height:1.3}
.event-time{font-size:10px;color:var(--text-400)}
.event-loc{font-size:10px;color:var(--text-400);margin-top:2px}
.event-cal{font-size:9px;letter-spacing:.5px;white-space:nowrap;padding-top:1px;flex-shrink:0;font-weight:600}
.around-label{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--text-400);margin:10px 0 6px;padding-top:8px;border-top:1px dashed var(--border)}
.reminder-pill{padding:7px 10px;border-radius:var(--radius-sm);background:var(--bg-200);border-left:3px solid transparent;margin-bottom:6px;display:flex;align-items:center;gap:8px}
.reminder-pill-overdue{padding:7px 10px;border-radius:var(--radius-sm);background:var(--danger-bg);border-left:3px solid var(--danger);margin-bottom:6px;display:flex;align-items:center;gap:8px}
.reminder-title{font-size:11px;font-weight:600;color:var(--text-100);flex:1;line-height:1.3}
.reminder-title-overdue{font-size:11px;font-weight:600;color:var(--danger);flex:1;line-height:1.3}
.reminder-list-tag{font-size:9px;letter-spacing:.5px;color:var(--text-400);white-space:nowrap;font-weight:500}
.reminder-divider{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--text-400);margin:12px 0 8px;padding-top:10px;border-top:1px dashed var(--border);font-weight:500}
.reminder-overdue-divider{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--danger);margin:12px 0 8px;padding-top:10px;border-top:1px dashed var(--danger-border);font-weight:500}

/* Stats grid */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:8px}
.stat-box{background:var(--bg-000);border:1px solid var(--border);border-radius:var(--radius-md);padding:14px;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.stat-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--text-400);margin-bottom:4px;font-weight:500}
.stat-val{font-size:26px;font-weight:700;color:var(--text-100);line-height:1}
.stat-unit{font-size:11px;color:var(--text-400);margin-top:3px}
.legend{display:flex;gap:16px;flex-wrap:wrap;padding:12px 0;border-bottom:1px solid var(--border)}
.legend-item{display:flex;align-items:center;gap:6px;font-size:10px;color:var(--text-400);letter-spacing:1px;text-transform:uppercase}
.legend-dot{width:7px;height:7px;border-radius:50%}

/* Sports / Events / Food */
.city-col{background:var(--bg-000);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.sport-item{padding:10px 0;border-bottom:1px solid var(--border)}
.sport-item:last-child{border-bottom:none;padding-bottom:0}
.sport-item-title{font-size:11px;font-weight:600;color:var(--text-100);margin-bottom:3px;line-height:1.3}
.sport-item-meta{font-size:10px;color:var(--text-400);line-height:1.4}
.sport-tag{display:inline-block;font-size:9px;letter-spacing:1px;text-transform:uppercase;border-radius:4px;padding:2px 7px;margin-top:4px;font-weight:600;border:1px solid transparent}
.home-tag{background:rgba(34,112,49,.1);color:rgb(34,112,49);border-color:rgba(34,112,49,.2)}
.event-item{padding:10px 0;border-bottom:1px solid var(--border)}
.event-item:last-child{border-bottom:none;padding-bottom:0}
.event-item-title{font-size:11px;font-weight:600;color:var(--text-100);margin-bottom:3px;line-height:1.3}
.event-item-meta{font-size:10px;color:var(--text-400);line-height:1.5}
.event-tag{display:inline-block;font-size:9px;letter-spacing:1px;text-transform:uppercase;border-radius:4px;padding:2px 7px;margin-top:4px;font-weight:600;border:1px solid transparent}
.food-cat-label{font-size:9px;letter-spacing:2px;text-transform:uppercase;font-weight:700;margin-bottom:6px;margin-top:16px}
.food-cat-label:first-child{margin-top:0}
.food-item{padding:7px 0;border-bottom:1px solid var(--border)}
.food-item:last-child{border-bottom:none}
.food-item-name{font-size:11px;font-weight:600;color:var(--text-100);margin-bottom:2px}
.food-item-addr{font-size:10px;color:var(--text-400);margin-bottom:3px}
.food-item-vibe{font-size:10px;color:var(--text-400);line-height:1.4;opacity:.85}
.seasonal-badge{display:inline-block;font-size:9px;letter-spacing:1px;text-transform:uppercase;border-radius:4px;padding:2px 6px;margin-top:4px;font-weight:600;background:rgba(207,92,54,.1);color:rgb(207,92,54);border:1px solid rgba(207,92,54,.25)}
.wind-pill{display:inline-flex;align-items:center;padding:1px 7px;border-radius:20px;font-size:9px;font-weight:600;letter-spacing:.3px;vertical-align:middle;margin-left:3px}
.w-calm{background:rgba(34,197,94,.12);color:rgb(21,128,61)}
.w-light{background:rgba(20,184,166,.12);color:rgb(15,118,110)}
.w-breezy{background:rgba(59,130,246,.12);color:rgb(29,78,216)}
.w-windy{background:rgba(251,146,60,.14);color:rgb(154,52,18)}
.w-vwindy{background:rgba(239,68,68,.12);color:rgb(153,27,27)}
.w-strong{background:rgba(139,92,246,.14);color:rgb(76,29,149)}
.walk-great{color:rgb(34,112,49)}.walk-decent{color:rgb(160,100,0)}.walk-tough{color:rgb(180,80,0)}.walk-skip{color:var(--danger)}
.footer{margin-top:24px;text-align:center;font-size:11px;color:var(--text-400);letter-spacing:.5px}
@media(prefers-color-scheme:dark){:root{color-scheme:light only}html,body{background:#faf9f5 !important;color:#141413 !important}.day-card{background:#ffffff !important;color:#141413 !important}.day-card.selected{background:#f0ede6 !important}.detail,.tod-card,.stat-box,.city-col{background:#ffffff !important;color:#141413 !important}}
@media(max-width:680px){.tod-row{grid-template-columns:1fr}.tod-card{border-right:none;border-bottom:1px solid var(--border)}.tod-card:last-child{border-bottom:none}.detail-grid{grid-template-columns:1fr}.detail-col{border-right:none!important;border-bottom:1px solid var(--border)}.detail-col:last-child{border-bottom:none}.stats-grid{grid-template-columns:repeat(2,1fr)}}
</style>
</head>
