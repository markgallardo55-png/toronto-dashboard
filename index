function _evDismiss(title){if(!_evSkipped.includes(title))_evSkipped.push(title);renderCityEvents();}
function renderCityEvents(){
  const visible=CITY_EVENTS.filter(e=>!_evSkipped.includes(e.title));
  const btn=`position:absolute;top:10px;right:10px;background:none;border:none;cursor:pointer;font-size:13px;color:var(--text-400);opacity:0.4;padding:2px 6px;line-height:1`;
  const items=visible.map(e=>{
    const sl=`https://www.google.com/search?q=${encodeURIComponent(e.title+' Toronto')}`;
    const safe=e.title.replace(/\\/g,'\\\\').replace(/'/g,"\\'");
    return`<div class="event-item" style="position:relative;padding-right:28px"><button class="_evx" data-t="${safe}" style="${btn}">✕</button><div class="event-item-title">${e.emoji} <a href="${sl}" target="_blank" style="color:inherit;border-bottom:1px solid rgba(31,30,29,0.2);text-decoration:none">${e.title}</a></div><div class="event-item-meta">${e.meta}</div>${e.location?`<div class="event-item-meta" style="margin-top:3px">📍 ${mapsLink(e.location,e.location)}</div>`:""}<span class="event-tag" style="background:${rgba(e.tagColor,0.1)};color:${e.tagColor};border-color:${rgba(e.tagColor,0.25)}">${e.tag}</span></div>`;
  }).join("");
  const skippedBar=_evSkipped.length?`<div style="margin-top:14px;padding:10px 12px;background:rgba(207,92,54,0.07);border-radius:8px;border:1px solid rgba(207,92,54,0.2)"><div style="font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:rgb(207,92,54);font-weight:700;margin-bottom:4px">Skipped — screenshot & send to Claude</div><div style="font-size:11px;color:var(--text-400)">${_evSkipped.join(', ')}</div></div>`:"";
  document.getElementById("events-col").innerHTML=`<div class="city-col">${items}${skippedBar}</div>`;
  document.querySelectorAll('._evx').forEach(b=>b.addEventListener('click',function(){_evDismiss(this.getAttribute('data-t'));}));
}

const _fdSkipped=[];
function _fdDismiss(title){if(!_fdSkipped.includes(title))_fdSkipped.push(title);renderFood();}
