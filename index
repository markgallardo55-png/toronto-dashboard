    if(!items.length)return`<div class="food-cat-label" style="color:${c}">${cat}</div><div style="font-size:11px;color:var(--text-400);padding-bottom:8px">More picks on next refresh.</div>`;
    return`<div class="food-cat-label" style="color:${c}">${cat}</div>`+items.map(f=>{
      const nameLink=`https://www.google.com/search?q=${encodeURIComponent(f.query)}`;
      const safe=f.title.replace(/\\/g,'\\\\').replace(/'/g,"\\'");
      return`<div class="food-item" style="position:relative;padding-right:16px"><button class="_fdx" data-fd="${safe}" style="${btn}">✕</button><div class="food-item-name">${f.emoji} <a href="${nameLink}" target="_blank" style="color:inherit;border-bottom:1px solid rgba(31,30,29,0.2);text-decoration:none">${f.title}</a></div>${f.seasonal?`<div><span class="seasonal-badge">Seasonal pick</span></div>`:""}<div class="food-item-addr">${mapsLink(f.address+' Toronto',f.address)}</div><div class="food-item-vibe">${f.vibe}</div></div>`;
    }).join("");
  }).join("")}</div>`).join("");
  const skippedBar=_fdSkipped.length?`<div style="margin-top:10px;padding:10px 12px;background:rgba(207,92,54,0.07);border-radius:8px;border:1px solid rgba(207,92,54,0.2);grid-column:1/-1"><div style="font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:rgb(207,92,54);font-weight:700;margin-bottom:4px">Skipped — screenshot & send to Claude</div><div style="font-size:11px;color:var(--text-400)">${_fdSkipped.join(', ')}</div></div>`:"";
  document.getElementById("food-col").innerHTML=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">${cols}${skippedBar}</div>`;
  document.querySelectorAll('._fdx').forEach(b=>b.addEventListener('click',function(){_fdDismiss(this.getAttribute('data-fd'));}));
}

// ═══════════════════════════════════════════════════════════════════════════════
// ██████  LIVE WEATHER — Open-Meteo fetch on every page load  ██████
// ═══════════════════════════════════════════════════════════════════════════════
//
// Open-Meteo API docs: https://open-meteo.com/en/docs
// Free, no API key required, CORS-enabled for browser use.
// Aggregation: max for hazards (wind/precip/weathercode), avg for temp.
// Worst-case ensures one rainy hour in an otherwise cloudy window still surfaces.

// WMO weathercode → emoji icon + human label
function wcToIconCond(wc){
  if(wc===0)                             return {icon:"☀️",   cond:"Clear"};
  if(wc===1||wc===2)                     return {icon:"⛅",   cond:"Partly cloudy"};
  if(wc===3)                             return {icon:"☁️",   cond:"Cloudy"};
  if(wc===45||wc===48)                   return {icon:"🌫️", cond:"Fog"};
  if(wc===51||wc===53||wc===55)          return {icon:"🌦️", cond:"Drizzle"};
  if(wc===56||wc===57)                   return {icon:"🌨️", cond:"Freezing drizzle"};
  if(wc===61||wc===63)                   return {icon:"🌧️", cond:"Rain"};
  if(wc===65)                            return {icon:"🌧️", cond:"Heavy rain"};
  if(wc===66||wc===67)                   return {icon:"🌨️", cond:"Freezing rain"};
  if(wc===71||wc===73)                   return {icon:"🌨️", cond:"Snow"};
  if(wc===75)                            return {icon:"❄️",   cond:"Heavy snow"};
  if(wc===77)                            return {icon:"🌨️", cond:"Snow grains"};
  if(wc===80||wc===81)                   return {icon:"🌦️", cond:"Rain showers"};
  if(wc===82)                            return {icon:"🌧️", cond:"Heavy showers"};
  if(wc===85||wc===86)                   return {icon:"🌨️", cond:"Snow showers"};
  if(wc===95)                            return {icon:"⛈️", cond:"Thunderstorm"};
  if(wc===96||wc===99)                   return {icon:"⛈️", cond:"Thunderstorm w/ hail"};
  return {icon:"❔", cond:"Unknown"};
}

function avg(arr){ return arr.length ? Math.round(arr.reduce((a,b)=>a+b,0)/arr.length) : 0; }

// Worst-case weathercode in an array — picks whichever hourly code carries
// the biggest walk-score penalty.
function worstWc(arr){
  const rank = wc => {
    if([95,96,99].includes(wc)) return 9;
    if([65,75,82,86].includes(wc)) return 8;
    if([61,71,80,85].includes(wc)) return 7;
    if([63,73,81].includes(wc)) return 6;
    if([45,48].includes(wc)) return 5;
    if([51,53,55,77].includes(wc)) return 4;
    if([56,57,66,67].includes(wc)) return 4;
    if(wc===3) return 3;
    if(wc===1||wc===2) return 2;
    if(wc===0) return 1;
    return 0;
  };
  let worst = arr[0]||0, worstRank = rank(worst);
  for(const w of arr){ const r=rank(w); if(r>worstRank){worstRank=r;worst=w;} }
  return worst;
}

function dayLabel(dateStr, idx){
  if(idx===0) return "Today";
  const d = new Date(dateStr+"T12:00:00");
  return d.toLocaleDateString("en-CA",{weekday:"short"});
}

function buildDaysFromOpenMeteo(data){
  const d = data.daily, h = data.hourly;
  const out = [];
  for(let i=0;i<d.time.length;i++){
    const date = d.time[i];
    const dailyWc = d.weathercode[i];
    const dailyIconCond = wcToIconCond(dailyWc);
    const hourIdx = [];
    for(let j=0;j<h.time.length;j++){
      if(h.time[j].startsWith(date)) hourIdx.push(j);
    }
    // Worst-case (max) for wind/precip/weathercode; avg for temp
    const slot = (from, to) => {
      const idx = hourIdx.filter(j=>{
        const hr = parseInt(h.time[j].slice(11,13),10);
        return hr>=from && hr<to;
      });
      const temp = avg(idx.map(j=>h.temperature_2m[j]));
      const wind = Math.max(0, ...idx.map(j=>h.windspeed_10m[j]));
      const precip = Math.max(0, ...idx.map(j=>h.precipitation_probability[j]||0));
      const wc = worstWc(idx.map(j=>h.weathercode[j]));
      const ic = wcToIconCond(wc);
      return {temp,wind:Math.round(wind),precip:Math.round(precip),weathercode:wc,icon:ic.icon,condition:ic.cond};
    };
    const m = slot(6,12), a = slot(12,18), e = slot(18,22);
    out.push({
      date, label: dayLabel(date, i),
      high: Math.round(d.temperature_2m_max[i]),
      low:  Math.round(d.temperature_2m_min[i]),
      condition: dailyIconCond.cond,
      icon: dailyIconCond.icon,
      precip: Math.round(d.precipitation_probability_max[i]||0),
      wind:   Math.round(d.windspeed_10m_max[i]||0),
      uv:     Math.round(d.uv_index_max[i]||0),
      weathercode: dailyWc,
      tod: [
        {period:"Morning",  ...m},
        {period:"Afternoon",...a},
        {period:"Evening",  ...e},
      ]
    });
  }
  return out;
}

function buildCurrentFromOpenMeteo(data){
  const h = data.hourly;
  const now = new Date();
  let closestIdx = 0, closestDelta = Infinity;
  for(let i=0;i<h.time.length;i++){
    const t = new Date(h.time[i]);
    const delta = Math.abs(t - now);
    if(delta < closestDelta){ closestDelta = delta; closestIdx = i; }
  }
  const temp = Math.round(h.temperature_2m[closestIdx]);
  const wind = Math.round(h.windspeed_10m[closestIdx]);
  const ic = wcToIconCond(h.weathercode[closestIdx]);
  const stamp = now.toLocaleDateString("en-CA",{weekday:"short",month:"short",day:"numeric"})
              + " · " + now.toLocaleTimeString("en-CA",{hour:"numeric",minute:"2-digit"});
  return {
    temp: `${temp}°C`,
    cond: `${ic.icon} ${ic.cond}`,
    wind: `${wind} km/h · 🇨🇦 Toronto`,
    refreshed: stamp
  };
}

async function bootDashboard(){
  const url = "https://api.open-meteo.com/v1/forecast"
    + "?latitude=43.64&longitude=-79.38"
    + "&daily=temperature_2m_max,temperature_2m_min,weathercode,precipitation_probability_max,windspeed_10m_max,uv_index_max"
    + "&hourly=temperature_2m,weathercode,precipitation_probability,windspeed_10m"
    + "&timezone=America/Toronto"
    + "&forecast_days=7";
  try{
    const res = await fetch(url);
    if(!res.ok) throw new Error("HTTP "+res.status);
    const data = await res.json();
    DAYS = buildDaysFromOpenMeteo(data);
    CURRENT = buildCurrentFromOpenMeteo(data);
  }catch(err){
    console.error("Open-Meteo fetch failed, using fallback:", err);
    CURRENT.refreshed = "⚠️ Live fetch failed — showing fallback · " + new Date().toLocaleString();
  }

  document.getElementById("cur-temp").textContent=CURRENT.temp;
  document.getElementById("cur-cond").textContent=CURRENT.cond;
  document.getElementById("cur-wind").textContent=CURRENT.wind;
  document.getElementById("footer").textContent="Open-Meteo · "+CURRENT.refreshed;

  renderCards(); renderDetail(); renderStats(); renderSports(); renderCityEvents(); renderFood();

  const wl=windLabel(DAYS[0].wind);
  const el=document.getElementById("cur-wind");
  if(el&&!el.textContent.includes(wl.label)) el.textContent=el.textContent+" · "+wl.label;
}

bootDashboard();
</script>
