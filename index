// ── HELPERS ──
function eventsFor(d){return EVENTS.filter(e=>e.date===d)}
function remindersFor(d){return REMINDERS.filter(r=>r.date===d)}
function cityEventsFor(d){return CITY_BY_DATE[d]||[]}
function windChill(temp,wind){if(temp>10||wind<5)return temp;return Math.round(13.12+0.6215*temp-11.37*Math.pow(wind,0.16)+0.3965*temp*Math.pow(wind,0.16))}
function rgba(rgb,a){return rgb.replace('rgb(','rgba(').replace(')',`,${a})`)}
function mapsLink(q,l){return`<a href="https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(q)}" target="_blank" style="color:inherit;border-bottom:1px solid rgba(31,30,29,0.2);text-decoration:none">${l}</a>`}
function windLabel(w){if(w<=10)return{label:"Calm",cls:"w-calm"};if(w<=20)return{label:"Light breeze",cls:"w-light"};if(w<=30)return{label:"Breezy",cls:"w-breezy"};if(w<=40)return{label:"Windy",cls:"w-windy"};if(w<=55)return{label:"Very windy",cls:"w-vwindy"};return{label:"Strong wind",cls:"w-strong"}}
function windPill(w){const wl=windLabel(w);return`<span class="wind-pill ${wl.cls}">${wl.label}</span>`}
function uvLabel(u){return(["Low","Low","Moderate","Moderate","High","High","High","Very High"][Math.min(u,7)])||"Low"}
function tempColor(t){if(t<=-10)return"rgb(96,130,220)";if(t<=0)return"rgb(80,140,210)";if(t<=5)return"rgb(60,120,180)";if(t<=12)return"rgb(160,100,0)";if(t<=20)return"rgb(180,80,0)";return"rgb(181,51,51)"}

function walkScore(precip,wind,temp,alert,wc){
  let s=100;if(alert)s-=50;
  if(wc!=null){if([95,96,99].includes(wc))s-=60;else if([65,75,82,86].includes(wc))s-=45;else if([61,71,80,85].includes(wc))s-=30;else if([63,73,81].includes(wc))s-=20;else if([51,53,55,77].includes(wc))s-=12;else if([45,48].includes(wc))s-=15;else if(wc===3)s-=5;}
  else{if(precip>=80)s-=40;else if(precip>=60)s-=25;else if(precip>=40)s-=15;else if(precip>=20)s-=8;}
  const felt=windChill(temp,wind);
  if(temp<=10){if(felt<=-20)s-=45;else if(felt<=-15)s-=35;else if(felt<=-10)s-=22;else if(felt<=-5)s-=12;else if(felt<=-2)s-=6;if(wind>=50)s-=10;else if(wind>=35)s-=5;}
  else{if(wind>=50)s-=25;else if(wind>=35)s-=15;else if(wind>=25)s-=8;else if(wind>=18)s-=3;
    // Pleasant temp bonus only if it's not raining/snowing/foggy
    const wetCodesForBonus=[45,48,51,53,55,56,57,61,63,65,66,67,71,73,75,77,80,81,82,85,86,95,96,99];
    const isWetForBonus = wc!=null && wetCodesForBonus.includes(wc);
    if(temp>=10&&temp<=22&&!isWetForBonus&&precip<30)s+=8;
  }
  return Math.max(0,Math.min(100,s));
}
function ratingFromScore(s, wc=null){
  // Wet-weather hard cap: if it's actively raining/snowing/storming,
  // cap label at "Decent" — common sense override regardless of score
  const wetHazardCodes=[51,53,55,56,57,61,63,65,66,67,71,73,75,80,81,82,85,86,95,96,99];
  const isWet = wc!=null && wetHazardCodes.includes(wc);
  if(s>=75 && !isWet) return{label:"Great", cls:"walk-great",dot:"rgb(34,112,49)", paw:"🐾🐾🐾",bar:"rgb(34,112,49)"};
  if(s>=75 &&  isWet) return{label:"Decent",cls:"walk-decent",dot:"rgb(160,100,0)",paw:"🐾🐾",  bar:"rgb(160,100,0)"};
  if(s>=50)           return{label:"Decent",cls:"walk-decent",dot:"rgb(160,100,0)",paw:"🐾🐾",  bar:"rgb(160,100,0)"};
  if(s>=25)           return{label:"Tough", cls:"walk-tough", dot:"rgb(180,80,0)", paw:"🐾",    bar:"rgb(180,80,0)"};
  return              {label:"Skip",  cls:"walk-skip",  dot:"rgb(181,51,51)",paw:"🚫",   bar:"rgb(181,51,51)"};
}

// ── GETTING READY LOGIC (Milo: Aussiedoodle, 45lb, curly coat, has orange rain jacket) ──
function miloTipsForTod(t,prevTod){
  const felt=windChill(t.temp,t.wind);
  const wc=t.weathercode??null;
  const wetCodes=[51,53,55,61,63,65,71,73,75,77,80,81,82,85,86,95,96,99];
  const isWet=wetCodes.includes(wc)||(wc===null&&t.precip>=30);
  const isVeryWet=[61,63,65,80,81,82,95,96,99].includes(wc)||(wc===null&&t.precip>=60)||t.alert;
  const recentRain=prevTod&&(prevTod.precip>=40||wetCodes.includes(prevTod.weathercode??-1));
  const wetGround=recentRain||isVeryWet;
  const mudRisk=wetGround&&t.precip>=30;
  const coldStress=felt<=-5;
  const tips=[];

  if(isVeryWet&&coldStress){
    tips.push({icon:"🧡",label:"Put his jacket on",note:"Heavy rain + cold — orange shell on"});
    tips.push({icon:"🛁",label:"Towel at the door",note:"Curly coat still needs a dry-off"});
  } else if(isVeryWet){
    tips.push({icon:"🧡",label:"Jacket recommended",note:"Cuts post-walk dry-off significantly"});
    tips.push({icon:"🛁",label:"Towel at the door",note:"Curly coat still holds moisture"});
  } else if(isWet){
    tips.push({icon:"🧴",label:"Quick wipe-down",note:"Check ears and paws after"});
  }
  if(mudRisk){tips.push({icon:"🐾",label:"Paw check at door",note:"Mud between toes — wipe at door"});}
  else if(wetGround){tips.push({icon:"🐾",label:"Check paws",note:"Wet ground — mud likely on trails"});}
  if(coldStress&&!isVeryWet){tips.push({icon:"🧡",label:"Consider his jacket",note:`Feels ${felt}° — jacket helps`});}
  if(!tips.length){tips.push({icon:"✅",label:"All clear for Milo",note:"Good to go"});}

  const dogHTML=tips.map(tp=>`<div class="tod-milo-tip"><div class="tod-milo-tip-icon">${tp.icon}</div><div class="tod-milo-tip-text"><div class="tod-milo-tip-label">${tp.label}</div><div class="tod-milo-tip-note">${tp.note}</div></div></div>`).join("");
  return`<div class="tod-milo-section"><div class="tod-ready-sub">For Milo 🐾</div>${dogHTML}</div>`;
}

function clothingForTod(t,prevTod=null){
  const felt=windChill(t.temp,t.wind);
  const wc=t.weathercode??null;
  const wetCodes=[51,53,55,61,63,65,71,73,75,77,80,81,82,85,86,95,96,99];
  const isWet=wetCodes.includes(wc)||(wc===null&&t.precip>=30);
  const isVeryWet=[61,63,65,80,81,82,95,96,99].includes(wc)||(wc===null&&t.precip>=60)||t.alert;
  const layers=[];
  const youTips=[];

  // Base layer: felt ≤6°C always; felt 7–10°C + wind ≥15 km/h
  if(felt<=6||(felt<=10&&t.wind>=15)){
    layers.push({icon:"🧵",piece:"Thin synthetic base",
      note:felt<=2?"Serious cold — layer up":t.wind>=15?"Wind chill — helps regulate heat":"Moisture management"});
  }

  // Insulating layer
  if(t.temp<=15){
    let piece,note;
    if(felt<=-8){piece="Down jacket";note="Add shell if rain picks up";}
    else if(isWet&&t.temp<=12){piece="Light puffer (standalone)";note="Handles light drizzle";}
    else if(t.temp<=8){piece="Light puffer or fleece";note="Works standalone in dry conditions";}
    else{piece="Light puffer or fleece";note="Standalone for this temp range";}
    layers.push({icon:"🧥",piece,note});
  }

  // Shell layer
  let shell=null,shellNote=null,alertTitle=null,alertSub=null;
  if(isVeryWet&&felt<=-2){shell="Waterproof shell";shellNote="Heavy rain + cold — wear it";alertTitle="Heavy rain + cold";alertSub="Full shell on — don't leave it behind";}
  else if(isVeryWet){shell="Ultralight waterproof shell";shellNote="Wear it";alertTitle="Heavy showers expected";alertSub="Don't leave without your shell";}
  else if(isWet&&t.precip>=40){shell="Ultralight waterproof shell";shellNote=t.precip>=60?"Showers likely — wear it":"Carry it or wear it";if(t.precip>=60){alertTitle="Showers likely";alertSub="Keep your shell on or within reach";}}
  else if(t.precip>=30){shell="Ultralight shell (optional)";shellNote="30% — toss it in your bag";}
  if(shell) layers.push({icon:"🌧️",piece:shell,note:shellNote});

  // Waterproof shoes
  const recentRain=prevTod&&(prevTod.precip>=40);
  if(isVeryWet||isWet||recentRain){youTips.push({icon:"👟",piece:"Waterproof shoes",note:"Skip the runners today"});}

  const alertHTML=alertTitle?`<div class="tod-rain-alert"><div class="tod-rain-alert-icon">🌧️</div><div class="tod-rain-alert-body"><div class="tod-rain-alert-title">${alertTitle}</div><div class="tod-rain-alert-sub">${alertSub}</div></div></div>`:"";
  const totalCount=layers.length+youTips.length;
  if(!totalCount&&!alertHTML) return`<hr class="tod-clothing-divider"><div class="tod-ready-heading">Getting Ready</div><div class="tod-ready-sub">For You</div><div style="font-size:10px;color:var(--text-400);font-style:italic">T-shirt weather ☀️</div>`+miloTipsForTod(t,prevTod);

  const layerHTML=layers.map(l=>`<div class="tod-layer-row"><div class="tod-layer-icon">${l.icon}</div><div class="tod-layer-inner"><div class="tod-layer-headline">${l.piece}</div>${l.note?`<div class="tod-layer-note">${l.note}</div>`:""}</div></div>`).join("");
  const youHTML=youTips.map(tp=>`<div class="tod-layer-row"><div class="tod-layer-icon">${tp.icon}</div><div class="tod-layer-inner"><div class="tod-layer-headline">${tp.piece}</div><div class="tod-layer-note">${tp.note}</div></div></div>`).join("");
  return`<hr class="tod-clothing-divider"><div class="tod-ready-heading">Getting Ready</div><div class="tod-ready-sub">For You · ${totalCount} layer${totalCount!==1?"s":""}</div>${alertHTML}${layerHTML}${youHTML}`+miloTipsForTod(t,prevTod);
}

// ── WALK INFO (full info for day-level) ──
function walkInfo(day,tod=null){
  const temp=tod?tod.temp:day.high;
  const wind=tod?tod.wind:day.wind;
  const precip=tod?tod.precip:day.precip;
  const wc=tod?(tod.weathercode??null):(day.weathercode??null);
  const alert=(tod?tod.alert:day.alert)||false;
  const s=walkScore(precip,wind,temp,alert,wc);
  const r=ratingFromScore(s,wc);
  const felt=windChill(temp,wind);
  return{score:s,felt,...r};
}

// Recomputed in renderCards() so live data refreshes the temp-bar scale
let minAll=0,maxAll=0,span=1;
let sel=0;

function renderCards(){
  // Recompute temperature scale from live data
  minAll=Math.min(...DAYS.map(d=>d.low));
  maxAll=Math.max(...DAYS.map(d=>d.high));
  span=maxAll-minAll||1;
  const row=document.getElementById("cards-row");row.innerHTML="";
  DAYS.forEach((day,i)=>{
    const evs=eventsFor(day.date);
    const isSel=i===sel;
    const bl=(day.low-minAll)/span*55+15,bw=Math.max((day.high-day.low)/span*50+10,8);
    const dateStr=new Date(day.date+"T12:00:00").toLocaleDateString("en-CA",{month:"short",day:"numeric"});
    const todDots=day.tod.map(t=>`<div class="walk-dot" style="background:${ratingFromScore(walkScore(t.precip,t.wind,t.temp,t.alert||false,t.weathercode??null),t.weathercode??null).dot}"></div>`).join("");

    // Pills: events + reminders (deduped) + city games
    const rems=remindersFor(day.date).filter(r=>!r.overdue);
    const evTitles=new Set(evs.map(e=>e.title.replace(/[^\w\s]/g,"").trim().toLowerCase()));
    const dedupedRems=rems.filter(r=>!evTitles.has(r.title.replace(/[^\w\s]/g,"").trim().toLowerCase()));
    const allPills=[...evs.map(e=>({type:"event",item:e})),...dedupedRems.map(r=>({type:"reminder",item:r}))];
    const maxPills=2;
    let pills="";
    for(let s2=0;s2<maxPills;s2++){
      const p=allPills[s2];
      if(p&&p.type==="event"){const ev=p.item;const t=ev.time?ev.time.replace(" AM","a").replace(" PM","p"):"";pills+=`<div class="pill-slot" style="background:${rgba(ev.color,0.1)};border:1px solid ${rgba(ev.color,0.2)}"><span class="pill-time">${t}</span><span class="pill-title">${ev.title}</span></div>`;}
      else if(p&&p.type==="reminder"){const r=p.item;const rtime=r.time?r.time.replace(" AM","a").replace(" PM","p"):"";pills+=`<div class="pill-slot" style="background:${rgba(r.color,0.08)};border:1px solid ${rgba(r.color,0.2)}"><span class="pill-time">${rtime?`⏰ ${rtime}`:`🔔 ${r.list}`}</span><span class="pill-title">${r.title}</span></div>`;}
      else{pills+=`<div class="pill-slot" style="background:transparent"></div>`;}
    }
    if(allPills.length>maxPills)pills+=`<div style="font-size:9px;color:var(--text-400);text-align:center;margin-top:2px">+${allPills.length-maxPills} more</div>`;

    const card=document.createElement("div");
    card.className=`day-card${isSel?" selected":""}`;
    card.innerHTML=`<div style="margin-bottom:8px"><div class="card-label">${day.label}</div><div class="card-date">${dateStr}</div></div><span class="card-icon">${day.icon}</span><span class="card-high" style="color:${tempColor(day.high)}">${day.high}°</span><span class="card-low">${day.low}°</span><div class="temp-bar-wrap"><div class="temp-bar" style="left:${bl}%;width:${bw}%"></div></div><div style="display:flex;justify-content:space-between;margin-top:3px"><span style="font-size:8px;color:var(--text-400)">${minAll}°</span><span style="font-size:8px;color:var(--text-400)">${maxAll}°</span></div><div class="walk-dot-wrap">${todDots}</div><div class="dot-label">AM · PM · EVE</div><div class="pills-area">${pills}</div>`;
    card.addEventListener("click",()=>{sel=i;renderCards();renderDetail();renderStats();setTimeout(()=>document.getElementById("detail").scrollIntoView({behavior:"smooth",block:"nearest"}),30);});
    row.appendChild(card);
  });
}

